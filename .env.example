# TuringResearch environment example.
# Copy to .env for local experiments only. Do not commit real values.

OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=

SEMANTIC_SCHOLAR_API_KEY=
APIFY_TOKEN=

TURINGRESEARCH_ENABLE_LIVE_TESTS=0
TURINGRESEARCH_CACHE=.cache/turingresearch
TURINGRESEARCH_VAULT_ROOT=.cache/turingresearch/vault

# Optional live adapter credentials. Leave blank for fake/default workflows.
GITHUB_TOKEN=
SFTP_HOST=
SFTP_USERNAME=
SFTP_KEY_PATH=
